# Copy to .env and fill in values. Never commit real secrets.

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/turbostudy

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:5173

# Base URL used by the Better Auth React client.
# - Dev (react-router dev): http://localhost:5173
# - Prod (react-router-serve): http://localhost:3000
VITE_BASE_URL=http://localhost:5173

# Google Gemini API key (used via LangChain)
GOOGLE_API_KEY=replace-with-your-google-ai-api-key
